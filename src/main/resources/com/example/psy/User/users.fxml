<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<AnchorPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="Controllers.User.UserListController"
            stylesheets="@../style.css"
            prefWidth="1000" prefHeight="650"
            styleClass="background-gradient">

    <!-- Bouton retour -->
    <Button text="← " onAction="#GoBack"
            styleClass="btn-secondary"
            prefHeight="35"
            AnchorPane.topAnchor="10"
            AnchorPane.leftAnchor="10"/>

    <VBox spacing="20"
          AnchorPane.topAnchor="50"
          AnchorPane.leftAnchor="30"
          AnchorPane.rightAnchor="30"
          AnchorPane.bottomAnchor="30">

        <!-- Header Card -->
        <HBox alignment="CENTER_LEFT" spacing="20"
              style="-fx-background-color: white; -fx-background-radius: 15; -fx-padding: 20; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 10, 0, 0, 0);">
            <Label text="User Management" styleClass="section-title"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="+ Add New User" onAction="#GoToUserAdd" styleClass="btn-primary"/>
        </HBox>

        <!-- Table Card -->
        <VBox spacing="15" VBox.vgrow="ALWAYS"
              style="-fx-background-color: white; -fx-background-radius: 15; -fx-padding: 20; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 10, 0, 0, 0);">

            <!-- Filtre de Recherche Unique & Intelligent -->
            <HBox spacing="15" alignment="BOTTOM_LEFT" style="-fx-background-color: #f8f9fa; -fx-padding: 15; -fx-background-radius: 10;">
                <VBox spacing="5" HBox.hgrow="ALWAYS">
                    <Label text="Recherche Globale (Nom, Email...)" style="-fx-font-weight: bold; -fx-font-size: 12px;"/>
                    <TextField fx:id="globalSearchField" promptText="Saisissez un nom, un prénom ou un email..." styleClass="form-control" prefHeight="38"/>
                </VBox>
                <VBox spacing="5">
                    <Label text="Filtrer par Rôle" style="-fx-font-weight: bold; -fx-font-size: 12px;"/>
                    <ComboBox fx:id="roleFilterBox" prefWidth="160" styleClass="form-control"/>
                </VBox>
                <Button text="↺" onAction="#loadUsers" styleClass="btn-secondary" prefHeight="38" style="-fx-font-size: 16px;"/>
                
                <Region prefWidth="20"/>
                
                <HBox spacing="10" alignment="BOTTOM_RIGHT">
                     <Button text="Modifier" onAction="#GoToUserEdit" styleClass="btn-secondary" prefHeight="38"/>
                     <Button text="Supprimer" onAction="#deleteUser" styleClass="logout-btn" prefHeight="38"/>
                </HBox>
            </HBox>

            <!-- TableView -->
            <TableView fx:id="userTable" VBox.vgrow="ALWAYS" styleClass="table-view">
                <columns>
                    <TableColumn text="ID" fx:id="idColumn" prefWidth="80"/>
                    <TableColumn text="Full Name" fx:id="nameColumn" prefWidth="250"/>
                    <TableColumn text="Email" fx:id="emailColumn" prefWidth="300"/>
                    <TableColumn text="Role" fx:id="roleColumn" prefWidth="150"/>
                    <TableColumn text="Actions" fx:id="actionsColumn" prefWidth="150"/>
                </columns>
                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                </columnResizePolicy>
            </TableView>
        </VBox>

    </VBox>

</AnchorPane>
